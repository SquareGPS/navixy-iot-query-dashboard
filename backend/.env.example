# Environment Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration (REQUIRED)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Redis Cache (optional - for query result caching)
REDIS_URL=redis://localhost:6379

# CORS Configuration (optional)
# Comma-separated list of additional allowed origins
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX_REQUESTS=5000

# Analytics Service (optional)
ANALYTICS_SERVICE_URL=http://localhost:8001

# AI dashboard agent (DO-313 / DO-342).
# AGENT_BACKEND selects the implementation: 'mock' (default) | 'bedrock'.
# The app MUST boot with zero AWS configuration — mock is the default for exactly that reason.
AGENT_BACKEND=mock

# Wall-clock deadline for one agent turn. CONSUMED BY routes/agent.ts, which arrives in
# MR 4 — listed here so the whole agent env surface lands in one place. It is NOT read by
# this service; the route owns the deadline and forwards it as ctx.signal (D21).
# Measured: ~7-8s for a clarifying question, ~36s for a full build (n=1). 180s is deliberate
# headroom.
AGENT_TIMEOUT_MS=180000

# --- only read when AGENT_BACKEND=bedrock ---
AWS_REGION=eu-central-1
# Credentials are read by the SDK's DEFAULT PROVIDER CHAIN from these standard names.
# Leave BOTH EMPTY in any environment that provides an ECS/EC2 task role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# Restrict artifact reads to one bucket. Empty = accept whatever bucket the agent names.
# SET THIS IN EVERY ENVIRONMENT; the empty default exists only so dev works before the
# bucket name is known. The URL arrives inside LLM-generated prose — see the SSRF note in
# artifactStore.
BEDROCK_ARTIFACT_BUCKET=

# Optional tuning; defaults live in bedrockAgent.ts / artifactStore.ts.
BEDROCK_CONNECTION_TIMEOUT_MS=5000
BEDROCK_REQUEST_TIMEOUT_MS=120000
BEDROCK_MAX_ATTEMPTS=2
AGENT_ARTIFACT_MAX_BYTES=5242880

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Note: Database connections are provided by users at login time.
# No DATABASE_URL configuration is needed.
