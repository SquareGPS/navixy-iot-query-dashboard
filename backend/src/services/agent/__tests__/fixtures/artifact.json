      "options": {},
      "x-navixy": {
        "sql": {
          "statement": "SELECT\n  o.object_label AS object_label,\n  COUNT(t.trip_start_time) AS trip_count,\n  ROUND(SUM(t.trip_distance_meters) / 1000.0, 2) AS total_distance_km\nFROM processed_common_data.trips t\nJOIN raw_business_data.objects o ON o.device_id = t.device_id\nWHERE o.is_deleted IS NOT TRUE\n  AND t.trip_start_time >= NOW() - INTERVAL '7 days'\n  AND t.trip_start_time < NOW()\nGROUP BY o.object_label\nORDER BY total_distance_km DESC",
          "params": {}
        },
