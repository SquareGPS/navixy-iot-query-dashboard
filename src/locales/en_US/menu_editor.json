    "paragraph": {
      "success": "Item renamed",
      "failure": "Failed to rename the item"
    }
  },
  "delete_section_toast": {
    "moved": {
      "paragraph": {
        "success": "Section deleted. Items moved to the root: {count}."
      }
    },
    "deleted": {
      "paragraph": {
        "success": "Section deleted. Items also deleted: {count}."
      }
    },
    "paragraph": {
      "failure": "Failed to delete the section"
    }
  },
  "delete_report_toast": {
    "paragraph": {
      "success": "Item deleted",
      "failure": "Failed to delete the item"
    }
  },
  "restore_section_toast": {
    "paragraph": {
      "success": "Section restored",
      "failure": "Failed to restore the section"
    }
  },
  "restore_report_toast": {
    "paragraph": {
      "success": "Item restored",
      "failure": "Failed to restore the item"
    }
  },
  "create_section_toast": {
    "paragraph": {
      "success": "Section created",
      "failure": "Failed to create the section"
    }
  },
  "create_dashboard_toast": {
    "paragraph": {
      "success": "Dashboard created",
      "failure": "Failed to create the dashboard"
    }
  }
