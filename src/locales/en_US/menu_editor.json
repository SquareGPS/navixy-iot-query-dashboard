    "search_input": {
      "placeholder": {
        "instruction": "Search…"
      }
    }
  },
  "tree": {
    "loading": {
      "paragraph": {
        "loading": "Loading menu…"
      }
    },
    "load_error": {
      "paragraph": {
        "failure": "Failed to load the menu"
      }
    },
    "drop_zone": {
      "paragraph": {
        "instruction": "Drop items here"
      }
    }
  },
  "done_editing_button": {
    "cta": "Done editing"
